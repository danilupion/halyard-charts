{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],
  // Supply-chain delay: only take releases that are at least 3 days old.
  minimumReleaseAge: '3 days',
  internalChecksFilter: 'strict',
  // Security fixes bypass minimumReleaseAge and are raised immediately; OSV
  // scanning broadens vulnerability detection beyond the platform's native alerts.
  osvVulnerabilityAlerts: true,
  packageRules: [
    {
      matchDatasources: ["docker"],
      matchUpdateTypes: ["digest"],
      groupName: "docker digests",
    },
    {
      // A digest is not a release and carries no timestamp, so minimumReleaseAge can
      // never be satisfied for one. Under the default timestamp-required behaviour such
      // updates are held as permanently-pending on renovate/stability-days; under
      // timestamp-optional they proceed but log a repo-problem WARN. Drop age gating for
      // digests entirely (it is meaningless for them) so every registry behaves the same
      // and the grouped "docker digests" branch is never wedged by a stuck member.
      matchUpdateTypes: ['digest'],
      minimumReleaseAge: null,
      prCreation: 'not-pending',
    },
    {
      // lscr.io/ghcr.io publish no release timestamps (renovatebot/renovate#38656,
      // renovatebot/renovate#39064), and since Renovate 42 a missing timestamp counts
      // as "never old enough", which would block these updates forever. Treat missing
      // timestamps as stable; the 3-day delay still applies wherever timestamps exist.
      // (Digest updates are handled separately above.)
      matchDatasources: ['docker'],
      matchPackageNames: ['lscr.io/**', 'ghcr.io/**'],
      minimumReleaseAgeBehaviour: 'timestamp-optional',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'lscr.io/linuxserver/lidarr',
      ],
      allowedVersions: '>=2.0.0 <8.0.0',
      versioning: 'semver',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'lscr.io/linuxserver/qbittorrent',
      ],
      allowedVersions: '>=5.0.0 <14.0.0',
      versioning: 'semver',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'lscr.io/linuxserver/jackett',
      ],
      versioning: 'semver',
    },
    {
      // Temporal 1.29.x ships only ES v7 index templates; 8.x and 9.x break auto-setup.
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'elasticsearch',
        'docker.io/elasticsearch',
        'docker.io/library/elasticsearch',
      ],
      allowedVersions: '<8.0.0',
      versioning: 'semver',
    },
    {
      // percona/mongodb_exporter only ever ships a 0.x line (latest 0.51.0). A
      // spurious "2.37.0" tag once outsorted the real 0.x releases and got pinned,
      // then was removed upstream, leaving Renovate unable to resolve its digest
      // ("Could not determine new digest for update"). Constrain to the real 0.x line.
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'percona/mongodb_exporter',
        'docker.io/percona/mongodb_exporter',
      ],
      allowedVersions: '<1.0.0',
      versioning: 'semver',
    }
  ]
}
