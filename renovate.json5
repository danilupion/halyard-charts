{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: ["config:best-practices"],
  packageRules: [
    {
      matchDatasources: ["docker"],
      matchUpdateTypes: ["digest"],
      groupName: "docker digests",
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'lscr.io/linuxserver/lidarr',
      ],
      allowedVersions: '>=2.0.0 <8.0.0',
      versioning: 'semver',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'lscr.io/linuxserver/qbittorrent',
      ],
      allowedVersions: '>=5.0.0 <14.0.0',
      versioning: 'semver',
    },
    {
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'lscr.io/linuxserver/jackett',
      ],
      versioning: 'semver',
    },
    {
      // Temporal 1.29.x ships only ES v7 index templates; 8.x and 9.x break auto-setup.
      matchDatasources: [
        'docker',
      ],
      matchPackageNames: [
        'elasticsearch',
        'docker.io/elasticsearch',
        'docker.io/library/elasticsearch',
      ],
      allowedVersions: '<8.0.0',
      versioning: 'semver',
    }
  ]
}
