{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"]
        }
      },
      "required": ["registry", "repository", "pullPolicy"]
    },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "service": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["ClusterIP", "NodePort", "LoadBalancer"]
        },
        "port": { "type": "integer" }
      },
      "required": ["type", "port"]
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "size": { "type": "string" }
      }
    },
    "database": {
      "type": "object",
      "properties": {
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string" }
      },
      "required": ["existingSecret", "existingSecretKey"]
    },
    "nextauth": {
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "existingSecret": { "type": "string" },
        "existingSecretKey": { "type": "string" }
      },
      "required": ["url", "existingSecret", "existingSecretKey"]
    },
    "linkwarden": {
      "type": "object",
      "properties": {
        "disableRegistration": { "type": "boolean" },
        "disablePreservation": { "type": "boolean" },
        "storageFolder": { "type": "string" }
      }
    }
  }
}
